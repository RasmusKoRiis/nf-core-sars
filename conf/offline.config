/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-core/sars offline resource caps
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Loaded only when params.offline is true. Normal online/server runs keep the
    defaults from conf/base.config and selected profiles.
----------------------------------------------------------------------------------------
*/

process {
    withLabel:process_medium {
        cpus = { Math.min(6 * task.attempt, 8) }
    }

    withLabel:process_high {
        cpus = { 8 }
    }

    withName:ARTIC_MINION_M {
        cpus = { Math.min((params.artic_threads ?: 4) as int, 8) }
    }
}
