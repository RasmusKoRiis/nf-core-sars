nextflow_process {

    name "Test Process MAKE_DEPTH_MASK"
    script "../main.nf"
    process "MAKE_DEPTH_MASK"

    tag "modules"
    tag "modules_local"
    tag "make_depth_mask"

    test("stub depth mask output") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'sample1' ],
                    file(params.local_test_data + '/module_test_dummy.bam', checkIfExists: true),
                    file(params.local_test_data + '/module_test_dummy.bam.bai', checkIfExists: true)
                ]
                input[1] = 20
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert file(process.out.lowcov[0][1]).getName() == 'sample1.lowcov.bed' },
                { assert path(process.out.versions.get(0)).text.contains('stub') }
            )
        }
    }
}
