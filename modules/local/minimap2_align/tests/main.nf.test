nextflow_process {

    name "Test Process MINIMAP2_ALIGN"
    script "../main.nf"
    process "MINIMAP2_ALIGN"

    tag "modules"
    tag "modules_local"
    tag "minimap2_align"

    test("stub minimap2 alignment output") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'sample1' ],
                    [
                        file(params.local_test_data + '/module_test_reads.fastq', checkIfExists: true),
                        file(params.local_test_data + '/module_test_reads_2.fastq', checkIfExists: true)
                    ]
                ]
                input[1] = file(params.local_test_data + '/module_test_reference.fasta', checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert file(process.out.minimap2[0][1]).getName() == 'sample1.bam' },
                { assert file(process.out.minimap2[0][2]).getName() == 'sample1.bam.bai' },
                { assert path(process.out.versions.get(0)).text.contains('stub') }
            )
        }
    }
}
