nextflow_process {

    name "Test Process PRIMER_MASK"
    script "../main.nf"
    process "PRIMER_MASK"

    tag "modules"
    tag "modules_local"
    tag "primer_mask"

    test("stub primer mask output") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'sample1' ],
                    file(params.local_test_data + '/module_test_lowcov.bed', checkIfExists: true)
                ]
                input[1] = file(params.local_test_data + '/module_test_scheme.bed', checkIfExists: true)
                input[2] = true
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert file(process.out.primer_mask[0][1]).getName() == 'sample1.mask.bed' },
                { assert path(process.out.versions.get(0)).text.contains('stub') }
            )
        }
    }
}
