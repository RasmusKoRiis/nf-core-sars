nextflow_process {

    name "Test Process REPORTFASTA"
    script "../main.nf"
    process "REPORTFASTA"

    tag "modules"
    tag "modules_local"
    tag "report_fasta"

    test("stub fasta report output") {

        options "-stub"

        when {
            process {
                """
                input[0] = file(params.local_test_data + '/module_test_report_stats.csv', checkIfExists: true)
                input[1] = file(params.local_test_data + '/module_test_report_mutations.csv', checkIfExists: true)
                input[2] = file(params.local_test_data + '/module_test_report_resistance.csv', checkIfExists: true)
                input[3] = "RUN001"
                input[4] = file(params.local_test_data + '/module_test_report_stats.csv', checkIfExists: true)
                input[5] = "pipeline=test"
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert file(process.out.report[0]).getName() == 'RUN001.csv' },
                { assert file(process.out.report_without_versions[0]).getName() == 'RUN001_without_software_versions.csv' },
                { assert file(process.out.report_with_versions[0]).getName() == 'RUN001_with_software_versions.csv' },
                { assert path(process.out.versions.get(0)).text.contains('stub') }
            )
        }
    }
}
